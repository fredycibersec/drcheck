# Domain Reputation Checker - Environment Variables
# Copy this file to .env and fill in your API keys

# VirusTotal API Key
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# URLScan.io API Key
URLSCAN_API_KEY=your_urlscan_api_key_here

# Abuse.ch (MalwareBazaar) API Key
ABUSECH_API_KEY=your_abusech_api_key_here

# APIVoid API Key (for URLVoid checks)
APIVOID_KEY=your_apivoid_api_key_here

# IP Geolocation APIs (need at least one)
IPAPI_ACCESS_KEY=your_ipapi_key_here
IPDATA_API_KEY=your_ipdata_key_here

# NetworksDB.io API Key (optional - network intelligence)
NETWORKSDB_API_KEY=your_networksdb_key_here

# SecurityTrails API Key (optional)
ST_API_KEY=your_securitytrails_key_here

# Shodan API Key (optional)
SHODAN_API_KEY=your_shodan_key_here

# Application Settings
FLASK_ENV=production
